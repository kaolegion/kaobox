#!/usr/bin/env bash
set -euo pipefail

# ==========================================================
# KAOBOX - Brain CLI Entry Point (Kernel v2.9)
# ----------------------------------------------------------
# - Symlink safe
# - Deterministic bootstrap
# - Minimal surface
# - Delegates to dispatcher only
# ==========================================================

# ----------------------------------------------------------
# Resolve script directory (symlink-safe)
# ----------------------------------------------------------

resolve_script_dir() {
    local SOURCE="${BASH_SOURCE[0]}"
    while [[ -h "$SOURCE" ]]; do
        local DIR
        DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
        SOURCE="$(readlink "$SOURCE")"
        [[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE"
    done
    cd -P "$(dirname "$SOURCE")" && pwd
}

SCRIPT_DIR="$(resolve_script_dir)"
KAOBOX_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
export KAOBOX_ROOT

# ----------------------------------------------------------
# Prevent interactive profile bootstrap
# ----------------------------------------------------------

export KAOBOX_SKIP_PROFILE=1

# ----------------------------------------------------------
# Load Dispatcher
# ----------------------------------------------------------

DISPATCHER="$KAOBOX_ROOT/lib/brain/dispatcher.sh"

[[ -f "$DISPATCHER" ]] || {
    echo "Fatal: dispatcher not found at $DISPATCHER"
    exit 1
}

# shellcheck source=/dev/null
source "$DISPATCHER"

# ----------------------------------------------------------
# Main Execution
# ----------------------------------------------------------

brain_dispatch "$@"
